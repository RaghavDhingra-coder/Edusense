# ============================================================
# DATABASE CONFIGURATION (PostgreSQL - Neon)
# ============================================================
DATABASE_URL=postgresql://neondb_owner:npg_Zne1j2xVYdCF@ep-solitary-glitter-aph1vflw-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ============================================================
# CLOUDINARY CONFIGURATION
# ============================================================
CLOUDINARY_CLOUD_NAME=dbmmnvf3y
CLOUDINARY_API_KEY=961666456133843
CLOUDINARY_API_SECRET=9ghMZ6mOGIPl6gYMqGk2RFXBigo

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=edusence-ai-secret-key-change-in-production-2024

# Server Configuration
HOST=0.0.0.0
PORT=8080

# ============================================================
# STORAGE CONFIGURATION
# ============================================================
# Temporary local storage for processing (auto-cleanup enabled)
TEMP_UPLOAD_DIR=temp_uploads
MAX_UPLOAD_SIZE_MB=500

# ============================================================
# AI MODEL CONFIGURATION
# ============================================================
# Device: 'cpu' or 'cuda:0'
DEVICE=cpu
USE_HALF_PRECISION=False

# Detection Settings
CONFIDENCE_THRESHOLD=0.4
MIN_FACE_WIDTH=30
MIN_FACE_HEIGHT=30
INFERENCE_SIZE=640

# Recognition Settings
ENABLE_REID=True
REID_SIMILARITY_THRESHOLD=0.6

# Head Pose Thresholds (degrees)
YAW_THRESHOLD=30.0
PITCH_THRESHOLD=30.0
ROLL_THRESHOLD=35.0

# ============================================================
# CLOUDINARY FOLDER STRUCTURE
# ============================================================
CLOUDINARY_REGISTERED_STUDENTS_FOLDER=edusence/registered_students
CLOUDINARY_SESSIONS_FOLDER=edusence/sessions
CLOUDINARY_UPLOADS_FOLDER=edusence/uploads
CLOUDINARY_ANALYTICS_FOLDER=edusence/analytics

# ============================================================
# PERFORMANCE SETTINGS
# ============================================================
# Background upload (async)
ENABLE_ASYNC_UPLOAD=True

# Upload queue settings
UPLOAD_QUEUE_SIZE=100
UPLOAD_JPEG_QUALITY=70
UPLOAD_RESIZE_WIDTH=224
UPLOAD_RESIZE_HEIGHT=224

# Smart saving (avoid redundant uploads)
ENABLE_SMART_SAVING=True
MIN_FRAMES_BETWEEN_SAVES=30

# Auto cleanup temporary files
AUTO_CLEANUP_TEMP_FILES=True
TEMP_FILE_RETENTION_SECONDS=300
