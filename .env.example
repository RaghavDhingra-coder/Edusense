# EduSence AI - Cloud Configuration Template
# Copy this file to .env and fill in your credentials

# ============================================================
# DATABASE CONFIGURATION (PostgreSQL - Neon)
# ============================================================
# Get your connection string from: https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/edusence_db?sslmode=require

# Database Connection Pool Settings (Production-Optimized)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================
# CLOUDINARY CONFIGURATION
# ============================================================
# Get your credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production

# Server Configuration
HOST=0.0.0.0
PORT=8080

# ============================================================
# STORAGE CONFIGURATION
# ============================================================
# Temporary local storage for processing (auto-cleanup enabled)
TEMP_UPLOAD_DIR=temp_uploads
MAX_UPLOAD_SIZE_MB=500

# ============================================================
# AI MODEL CONFIGURATION
# ============================================================
# Device: 'cpu' or 'cuda:0'
DEVICE=cpu
USE_HALF_PRECISION=False

# Detection Settings
CONFIDENCE_THRESHOLD=0.4
MIN_FACE_WIDTH=30
MIN_FACE_HEIGHT=30
INFERENCE_SIZE=640

# Recognition Settings
ENABLE_REID=True
REID_SIMILARITY_THRESHOLD=0.60
RECOGNITION_CONFIDENCE_THRESHOLD=0.60

# Recognition Engine Optimization
RECOGNITION_TEMPORAL_SMOOTHING=5
RECOGNITION_MIN_CONSENSUS=3
RECOGNITION_CACHE_ENABLED=True

# Head Pose Thresholds (degrees)
YAW_THRESHOLD=30.0
PITCH_THRESHOLD=30.0
ROLL_THRESHOLD=35.0

# ============================================================
# CLOUDINARY FOLDER STRUCTURE
# ============================================================
CLOUDINARY_REGISTERED_STUDENTS_FOLDER=edusence/registered_students
CLOUDINARY_SESSIONS_FOLDER=edusence/sessions
CLOUDINARY_UPLOADS_FOLDER=edusence/uploads
CLOUDINARY_ANALYTICS_FOLDER=edusence/analytics

# ============================================================
# PERFORMANCE SETTINGS
# ============================================================
# Background upload (async)
ENABLE_ASYNC_UPLOAD=True

# Upload queue settings
UPLOAD_QUEUE_SIZE=100
UPLOAD_JPEG_QUALITY=85
UPLOAD_RESIZE_WIDTH=256
UPLOAD_RESIZE_HEIGHT=256

# Temp analysis buffer (high quality local storage for accurate analysis)
ENABLE_TEMP_ANALYSIS_BUFFER=True
ANALYSIS_JPEG_QUALITY=95
ANALYSIS_MIN_SIZE=112

# Smart saving (avoid redundant uploads)
ENABLE_SMART_SAVING=True
MIN_FRAMES_BETWEEN_SAVES=30

# Auto cleanup temporary files
AUTO_CLEANUP_TEMP_FILES=True
TEMP_FILE_RETENTION_SECONDS=300
